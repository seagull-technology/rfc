APP_NAME="RFC e-Permit"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://RFC_PUBLIC_HOST
APP_TIMEZONE=Asia/Amman

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=single
LOG_LEVEL=warning
LOG_DAILY_DAYS=30

DB_CONNECTION=mysql
DB_HOST=DATABASE_HOST
DB_PORT=3306
DB_DATABASE=DATABASE_NAME
DB_USERNAME=DATABASE_USER
DB_PASSWORD="DATABASE_PASSWORD"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Keep log delivery until an SMTP relay is supplied and reachable from the VM.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@rfc.local
MAIL_FROM_NAME="${APP_NAME}"

# These credentials are used only when AccessControlSeeder creates the two
# initial system owners. Use unique one-time passwords and rotate them after
# first login.
INITIAL_SUPER_ADMIN_NAME="Platform Super Admin"
INITIAL_SUPER_ADMIN_USERNAME=superadmin
INITIAL_SUPER_ADMIN_EMAIL=superadmin@rfc.local
INITIAL_SUPER_ADMIN_NATIONAL_ID=9999999999
INITIAL_SUPER_ADMIN_PHONE=0790000099
INITIAL_SUPER_ADMIN_PASSWORD="CHANGE_ME_BEFORE_SEEDING"

INITIAL_RFC_OWNER_NAME="RFC Owner Account"
INITIAL_RFC_OWNER_USERNAME=rfc_owner
INITIAL_RFC_OWNER_EMAIL=ref@ref.test
INITIAL_RFC_OWNER_NATIONAL_ID=2000012345
INITIAL_RFC_OWNER_PHONE=0791231233
INITIAL_RFC_OWNER_PASSWORD="CHANGE_ME_BEFORE_SEEDING"

# Government SMS and OTP. Debug fallback must remain false outside staging.
GOV_SMS_BASE=https://bulk-sms.gov.jo
GOV_SMS_USER=
GOV_SMS_PASS=
GOV_SMS_HEADER=rfc
GOV_SMS_MESSAGE_TYPE_ID=3
OTP_DEBUG_FALLBACK=false

# Government Service Bus shared transport.
GSB_ENABLED=true
GSB_ENVIRONMENT=stg
GSB_BASE_URL=https://api-gateway.stg.gsb.gov.jo:9443
GSB_FORCE_IP=
GSB_TIMEOUT=25
GSB_CACHE_MINUTES=10
GSB_CREW_VERIFICATION_MINUTES=120
GSB_CLIENT_ID=
GSB_CLIENT_SECRET=
GSB_BASIC_USER=RFC_STG
GSB_BASIC_PASS=
GSB_BEARER=
GSB_SEND_MODEE_HEADERS=true
GSB_SEND_IBM_HEADERS=false

# MOHE Standard Undergraduate Students API v1.0.3.
GSB_MOHE_UNDERGRADUATE_ENABLED=true
GSB_MOHE_UNDERGRADUATE_PATH=/porg-g2g/g2g/api/LastSemester
GSB_MOHE_UNDERGRADUATE_METHOD=POST

# Jordanian individual lookup for registration, personal details, and crew.
GSB_CSPD_MASKED_ENABLED=true
GSB_CSPD_MASKED_PATH=/porg-g2g/g2g/masked/api/person-info
GSB_CSPD_MASKED_METHOD=GET
GSB_CSPD_MASKED_PSD_PATH=/porg-g2g/g2g/masked/api/psd

# Keep the CSPD token product disabled for arbitrary-person lookups. Its token
# represents a specific identity rather than accepting any national number.
GSB_CSPD_TOKEN_ENABLED=false
GSB_CSPD_TOKEN_PATH=/porg-g2g/g2g/token/person-info
GSB_CSPD_TOKEN_METHOD=GET
GSB_CSPD_TOKEN_BEARER=

# Non-Jordanian personal details and crew lookup.
GSB_PSD_BASIC_INFO_ENABLED=true
GSB_PSD_BASIC_INFO_PATH=/porg-g2g/g2g/token/psd
GSB_PSD_BASIC_INFO_METHOD=POST
GSB_PSD_BASIC_INFO_BEARER=

# Government company registries. The application tries CCD, then MIT.
GSB_CCD_COMPANY_ENABLED=true
GSB_CCD_COMPANY_PATH=/porg-g2g/g2g/api/companies/CompanybyNo/{nationalNo}
GSB_CCD_COMPANY_METHOD=GET
GSB_MIT_SERVICES_ENABLED=true
GSB_MIT_SERVICES_PATH=/porg-g2g/g2g/api/Registry/getIndividualRegistry
GSB_MIT_SERVICES_METHOD=POST

# SANAD / SignFlow. Enable only after MODEE provides and registers the browser
# authorization endpoint and callback.
GSB_SIGNFLOW_V2_ENABLED=false
GSB_SIGNFLOW_V2_PATH=/porg-g2g/g2g/signflow/v2
GSB_SIGNFLOW_V2_METHOD=POST
GSB_SIGNFLOW_V2_OPEN_ENABLED=false
GSB_SIGNFLOW_V2_OPEN_PATH=/porg-g2g/g2g/signflow/v2
GSB_SIGNFLOW_V2_OPEN_METHOD=POST
SANAD_AUTHORIZATION_URL=
SANAD_CLIENT_ID=
SANAD_CLIENT_SECRET=
SANAD_REDIRECT_URI=https://RFC_PUBLIC_HOST/ar/login/sanad/callback
SANAD_SCOPE=openid

# Legacy company integration. Keep disabled while CCD/MIT GSB services are in use.
GOV_COMPANY_REGISTRY_ENABLED=false
GOV_COMPANY_REGISTRY_HOST=
GOV_COMPANY_REGISTRY_PORT=9443
GOV_COMPANY_REGISTRY_FORCE_IP=
GOV_COMPANY_REGISTRY_PATH=/porg-g2g/g2g/MoaApi/api/GetDataByNationalId
GOV_COMPANY_REGISTRY_TIMEOUT=25
GOV_COMPANY_REGISTRY_CLIENT_ID="${GSB_CLIENT_ID}"
GOV_COMPANY_REGISTRY_CLIENT_SECRET="${GSB_CLIENT_SECRET}"
GOV_COMPANY_REGISTRY_MODEE_CLIENT_ID="${GSB_CLIENT_ID}"
GOV_COMPANY_REGISTRY_MODEE_CLIENT_SECRET="${GSB_CLIENT_SECRET}"
GOV_COMPANY_REGISTRY_SEND_IBM_HEADERS=false
GOV_COMPANY_REGISTRY_SEND_MODEE_HEADERS=true
GOV_COMPANY_REGISTRY_BASIC_USER=
GOV_COMPANY_REGISTRY_BASIC_PASS=
GOV_COMPANY_REGISTRY_BEARER=
GOV_COMPANY_REGISTRY_CACHE_MINUTES=5
